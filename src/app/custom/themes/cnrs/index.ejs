<!DOCTYPE html>
<html>
<head>
    <title>Lodex - CNRS</title>
    <meta charset="utf-8"/>
    <meta http-equiv="X-UA-Compatible" content="IE=edge"/>
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=0"/>
    <link rel="apple-touch-icon" sizes="180x180" href="<%= theme.current.href %>/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="<%= theme.current.href %>/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="<%= theme.current.href %>/favicon-16x16.png">
    <link rel="manifest" href="<%= theme.current.href %>/site.webmanifest">
    <link rel="mask-icon" href="<%= theme.current.href %>/safari-pinned-tab.svg" color="#ffc40d">
    <meta name="msapplication-TileColor" content="#ffc40d">
    <meta name="theme-color" content="#ffc40d">
    <link rel="preload" href="<%= lodex.base.href %>/fonts/ibmplexsans-variablefont_wdthwght-webfont.woff2" as="font" type="font/woff2" crossorigin>
    <link rel="preload" href="<%= lodex.base.href %>/fonts/satoshi-regular-webfont.woff2" as="font" type="font/woff2" crossorigin>
    <link rel="stylesheet" href="<%= lodex.base.href %>/styles/normalize.min.css"/>
    <link rel="stylesheet" href="<%= lodex.base.href %>/styles/fonts.css"/>
    <link rel="stylesheet" href="<%= theme.current.href %>/css/cnrs-styles.css"/>
    <link rel="stylesheet" href="<%= lodex.base.href %>/css/front-LeafletMap.css"/>
    <style><%= theme.cssVariable %></style>
</head>
<body>
<header>
    <div class="container">
        <div id="Editeurs">
            <a class="logo cnrs" href="https://www.cnrs.fr">
                <img src="<%= theme.current.href %>/img/cnrs-blanc.svg" alt="CNRS"/>
            </a>
        <% if (custom.cotutelle1 && custom.cotutelle1.siteWebUrl != null) { %>
            <a class="logo cotutelle cotutelle1" href="<%= custom.cotutelle1.siteWebUrl %>" target="_blank">
                <img src="<%= custom.cotutelle1.logoFileUrl %>" alt="<%= custom.cotutelle1.logoTexteAlternatif %>" width="<%= custom.cotutelle1.logoLargeur %>"/>
            </a>
        <% }
        if (custom.cotutelle2 && custom.cotutelle2.siteWebUrl != null ) { %>
            <a class="logo cotutelle  cotutelle2" href="<%= custom.cotutelle2.siteWebUrl %>" target="_blank">
                <img src="<%= custom.cotutelle2.logoFileUrl %>" alt="<%= custom.cotutelle2.logoTexteAlternatif %>" width="<%= custom.cotutelle2.logoLargeur %>"/>
            </a>
        <% }
        if (custom.cotutelle3 && custom.cotutelle3.siteWebUrl != "" ) { %>
            <a class="logo cotutelle cotutelle3" href="<%= custom.cotutelle3.siteWebUrl %>" target="_blank">
                <img src="<%= custom.cotutelle3.logoFileUrl %>" alt="<%= custom.cotutelle3.logoTexteAlternatif %>" width="<%= custom.cotutelle3.logoLargeur %>"/>
            </a>
        <% } 
        if (custom.unite ) { %>
            <a class="logo unite" href="<%= custom.unite.siteWebUrl %>" aria-label="accueil du site">
                <span><%= custom.unite.sigle %></span>
                <span class="uniteIntitule"><%= custom.unite.intitule %></span>
            </a>
        <% } %>
        </div>
        <% if (custom.siteTitle ) { %>
        <h1 id="titre_lodex" class="bl3">
            <a href="/instance/<%= lodex.tenant %>"><%= custom.siteTitle %></a>
        </h1>
            <% } %>
    </div>
</header>
<div id="root"></div>
<footer class="bt">
    <p><a href="https://www.inist.fr"><img src="<%= theme.current.href %>/img/Opere_par_Inist long.png" width="120px" alt="opéré par CNRS Inist"></a></p>
</footer>
<% if (isDev) { %>
    <script type="module">
        import RefreshRuntime from '<%= lodex.base.href %>/@react-refresh'
        RefreshRuntime.injectIntoGlobalHook(window)
        window.$RefreshReg$ = () => {}
        window.$RefreshSig$ = () => (type) => type
        window.__vite_plugin_react_preamble_installed__ = true
    </script>
    <script type="module" src="<%= lodex.base.href %>/@vite/client"></script>
<% } %>
<script>
    window.__PRELOADED_STATE__ = <%- lodex.preload %>;
    window.__TENANT__ = '<%= lodex.tenant %>';
    window.ISTEX_API_URL = '<%= lodex.istexApi %>';
</script>
<script type="module" src="<%= lodex.base.href %>/public/index.js"></script>
    <% if (custom.matomoID && custom.matomoHost) { %>
        <!-- Piwik -->
        <script>
            var _paq = _paq || [];
            _paq.push([
                function () {
                    var self = this;
                    function getOriginalVisitorCookieTimeout() {
                        var now = new Date(),
                            nowTs = Math.round(now.getTime() / 1000),
                            visitorInfo = self.getVisitorInfo();
                        var createTs = parseInt(visitorInfo[2]);
                        var cookieTimeout = 33696000;
                        var originalTimeout = createTs + cookieTimeout - nowTs;
                        return originalTimeout;
                    }
                    this.setVisitorCookieTimeout(getOriginalVisitorCookieTimeout());
                }
            ]);
            _paq.push(["trackPageView"]);
            _paq.push(["enableLinkTracking"]);
            (function () {
                var u = "<%= custom.matomoHost %>";
                _paq.push(["setTrackerUrl", u + "piwik.php"]);
                _paq.push(["setSiteId", "<%= custom.matomoID %>"]);
                var d = document,
                    g = d.createElement("script"),
                    s = d.getElementsByTagName("script")[0];
                g.type = "text/javascript";
                g.async = true;
                g.defer = true;
                g.src = u + "piwik.js";
                s.parentNode.insertBefore(g, s);
            })();
        </script>
        <!-- End Piwik Code -->
    <% } %>
</body>
</html>
